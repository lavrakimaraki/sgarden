{
  "name": "sgarden",
  "version": "1.0.0",
  "private": true,
  "description": "Unified Sgarden project with frontend and backend subfolders.",
  "type": "module",
  "main": "backend/server.js",
  "scripts": {
    "frontend:start": "cd frontend && npx craco start",
    "frontend:build": "cd frontend && npx craco build",
    "frontend:serve": "cd frontend && npx serve -s -l 3050 build",
    "frontend:lint": "eslint frontend --cache",
    "frontend:cypress:open": "cd frontend && npx cypress open",
    "frontend:cypress:run": "cd frontend && npx cypress run",
    "smoke:seed": "node seed-test-users.js",
    "smoke:test": "node frontend/run-smoke-tests.js",
    "smoke:test:auto": "node scripts/run-smoke-with-services.mjs",
    "smoke:open": "cd frontend && npx cypress open --config-file cypress.config.js",
    "backend:dev": "cross-env NODE_ENV=development NODE_OPTIONS=--trace-warnings DOTENV_CONFIG_PATH=backend/.env nodemon backend/server.js --watch backend/src --watch backend/server.js --watch backend/.env",
    "backend:start": "cross-env NODE_ENV=production DOTENV_CONFIG_PATH=backend/.env node backend/server.js",
    "backend:lint": "eslint backend --cache",
    "backend:test": "node -e \"console.log('No backend tests found in this merged copy; skipping.')\"",
    "dev": "concurrently -n backend,frontend -c yellow,cyan \"npm run backend:dev\" \"npm run frontend:start\"",
    "start": "npm run backend:start",
    "start:all": "concurrently -n backend,frontend -c yellow,cyan \"npm run backend:start\" \"npm run frontend:serve\"",
    "lint": "npm run frontend:lint && npm run backend:lint",
    "test": "node scripts/run-smoke-with-services.mjs"
  },
  "browserslist": {
    "production": [
      ">1%",
      "not dead",
      "not op_mini all",
      "not ie > 0",
      "not ie_mob > 0"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "prettier": "@iamnapo/prettier-config",
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "frontend/**/*.{js,jsx}"
        ],
        "extends": [
          "iamnapo/react"
        ],
        "rules": {
          "unicorn/prefer-module": "off",
          "unicorn/prefer-string-replace-all": "error",
          "unicorn/prefer-at": "error",
          "import/no-unresolved": "off"
        }
      },
      {
        "files": [
          "backend/**/*.js"
        ],
        "extends": [
          "iamnapo"
        ],
        "rules": {
          "import/no-unresolved": [
            "error",
            {
              "ignore": [
                "ava",
                "got"
              ]
            }
          ]
        }
      },
      {
        "files": [
          "scripts/**/*.js"
        ],
        "env": {
          "node": true
        },
        "parserOptions": {
          "ecmaVersion": 2022,
          "sourceType": "module"
        }
      },
      {
        "files": [
          "scripts/cypress.config.js"
        ],
        "env": {
          "node": true
        },
        "parserOptions": {
          "ecmaVersion": 2022,
          "sourceType": "script"
        }
      },
      {
        "files": [
          "scripts/**/*.mjs"
        ],
        "env": {
          "node": true
        },
        "parserOptions": {
          "ecmaVersion": 2022,
          "sourceType": "module"
        }
      }
    ],
    "ignorePatterns": [
      "frontend/build"
    ]
  },
  "ava": {
    "timeout": "1m",
    "verbose": true
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@iamnapo/sort": "^2.2.0",
    "@mui/icons-material": "^5.16.7",
    "@mui/lab": "^5.0.0-alpha.173",
    "@mui/material": "^5.16.7",
    "@mui/styles": "^5.16.7",
    "@mui/x-date-pickers": "^6.20.2",
    "@sendgrid/mail": "^8.1.3",
    "@sentry/browser": "^7.119.0",
    "@sentry/node": "^7.119.0",
    "bcryptjs": "^2.4.3",
    "bulma": "^1.0.2",
    "chalk": "^5.3.0",
    "clsx": "^2.1.1",
    "color-harmony": "^0.3.0",
    "compression": "^1.7.4",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "formik": "^2.4.6",
    "helmet": "^7.2.0",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "ky": "^1.7.2",
    "match-sorter": "^6.3.4",
    "mongoose": "^7.8.2",
    "mongoose-lean-defaults": "^2.2.1",
    "morgan": "^1.10.0",
    "mui-image": "^1.0.7",
    "plotly.js": "^2.35.2",
    "prop-types": "^15.8.1",
    "query-string": "^9.1.0",
    "ramda": "^0.30.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.0.13",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.26.2",
    "react-simple-maps": "^3.0.0",
    "react-table-6": "^6.11.0",
    "serve-favicon": "^2.5.0",
    "styled-components": "^6.1.13",
    "swr": "^2.2.5",
    "yup": "^1.4.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@iamnapo/prettier-config": "^1.0.3",
    "ajv": "^8.17.1",
    "ava": "^6.1.3",
    "babel-plugin-import": "^1.13.8",
    "c8": "^10.1.2",
    "cypress": "^13.15.0",
    "eslint": "^8.57.1",
    "eslint-config-iamnapo": "^28.2.0",
    "events": "^3.3.0",
    "got": "^14.4.2",
    "nodemon": "^3.1.7",
    "react-scripts": "^5.0.1",
    "sass": "^1.79.5",
    "serve": "^14.2.3",
    "source-map-explorer": "^2.5.3",
    "start-server-and-test": "^2.0.8",
    "test-listen": "^1.1.0",
    "url": "^0.11.4"
  },
  "resolutions": {
    "axios": "^1.7.7",
    "d3-color": "^3.1.0",
    "fast-xml-parser": "^4.5.0",
    "nth-check": "^2.1.1",
    "postcss": "^8.4.47",
    "semver": "^7.6.3",
    "serialize-javascript": "^6.0.2",
    "underscore": "^1.13.7",
    "uuid": "^10.0.0",
    "sockjs": "^0.3.24"
  },
  "overrides": {
    "axios": "^1.7.7",
    "d3-color": "^3.1.0",
    "fast-xml-parser": "^4.5.0",
    "nth-check": "^2.1.1",
    "postcss": "^8.4.47",
    "semver": "^7.6.3",
    "serialize-javascript": "^6.0.2",
    "underscore": "^1.13.7",
    "uuid": "^10.0.0",
    "sockjs": "^0.3.24",
    "@tootallnate/once": "^2.0.0",
    "http-proxy-agent": "^5.0.0",
    "jsdom": "^22.1.0"
  }
}